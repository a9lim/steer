Screen {
    layout: vertical;
    background: ansi_default;
    color: ansi_default;

    .screen--selection {
        background: ansi_white;
        color: ansi_black;
    }
}

/* Force all widgets to inherit terminal colors */
Widget {
    background: ansi_default;
    color: ansi_default;
    scrollbar-color: ansi_bright_black;
    scrollbar-color-hover: ansi_default;
    scrollbar-color-active: ansi_default;
    scrollbar-background: ansi_default;
    scrollbar-background-hover: ansi_default;
    scrollbar-background-active: ansi_default;
    link-color: ansi_default;
    link-background: ansi_default;
    link-style: underline;
    link-color-hover: ansi_default;
    link-background-hover: ansi_default;
    link-style-hover: bold underline;
}

#main-area {
    height: 1fr;
    layout: horizontal;
}

/* Three-column layout: left (1fr) | center (2fr) | right (1fr) */
#left-panel {
    width: 1fr;
    height: 100%;
    border-right: solid ansi_default;
    padding: 0 1;
    layout: vertical;
}

#chat-panel {
    width: 2fr;
    height: 100%;
    layout: vertical;
}

#trait-panel {
    width: 1fr;
    height: 100%;
    border-left: solid ansi_default;
    padding: 0 1;
    layout: vertical;
}

/* Panel focus highlighting */
#left-panel.focused {
    border-right: double ansi_yellow;
}

#trait-panel.focused {
    border-left: double ansi_yellow;
}

/* Left panel sections */
.section-header {
    color: ansi_yellow;
    text-style: bold;
    height: 1;
}

.section-body {
    height: auto;
    padding: 0 1;
}

#model-section {
    height: auto;
}

#vectors-section {
    height: 1fr;
    min-height: 5;
}

#vector-scroll {
    height: 1fr;
    overflow-y: auto;
}

#gen-section {
    height: auto;
}

#keys-section {
    height: auto;
}

.vector-row {
    height: auto;
}

.vector-row-selected {
    height: auto;
    background: ansi_default;
}

/* Chat panel internals */
#chat-log {
    height: 1fr;
    overflow-y: auto;
    padding: 0 1;
}

#status-bar {
    height: 1;
    background: ansi_default;
    color: ansi_default;
    padding: 0 1;
}

/* ChatInput (TextArea subclass): single visible row by default, grows
 * with content up to a small cap so the chat log stays the focus of the
 * screen.  ``height: auto`` lets the widget hug its content; the
 * min/max bound the visible rows.  ``dock: bottom`` pins it under the
 * status bar.  Background/border match the surrounding ansi theme so
 * the multi-line variant blends in the same way the old single-line
 * Input did.
 */
#chat-input {
    height: auto;
    min-height: 3;
    max-height: 10;
    dock: bottom;
    border: solid ansi_default;
    background: ansi_default;
    color: ansi_default;
}

/* Override Textual's default focus border */
#chat-input:focus {
    border: solid ansi_default;
}

/* TextArea exposes its selection style through ``.text-area--selection``
 * (vs the old ``Input.input--selection``).  Keep the inverted look so
 * a selection stays visible against the ansi background.
 */
#chat-input > .text-area--selection {
    background: ansi_white;
    color: ansi_black;
}

.user-message,
.assistant-message {
    margin-bottom: 1;
    height: auto;
}

.system-message {
    margin-bottom: 1;
    height: auto;
}

/* A/B turn rows.
 *
 * Each user / assistant turn lives in a Horizontal with two columns. The
 * shadow column is hidden when AB mode is off so the primary column owns
 * the full width — pre-AB rendering is unchanged. With ``.ab-on`` on the
 * chat panel both columns share width 1fr, the inner widgets fall into
 * lockstep, and Textual's max-child-height row sizing keeps them row-
 * aligned without an explicit grid. */
.turn-row {
    height: auto;
    layout: horizontal;
}

.turn-col {
    width: 1fr;
    height: auto;
    padding: 0 0;
}

.turn-col.shadow {
    display: none;
    padding-left: 1;
}

ChatPanel.ab-on .turn-col.shadow {
    display: block;
    border-left: solid ansi_bright_black;
}

.shadow-placeholder {
    color: ansi_bright_black;
    text-style: italic;
    height: 1;
}

.shadow-message {
    /* Tag visible to readers — no behavioural diff vs. primary widget. */
}


/* Thinking block (Qwen 3.5, QwQ, etc.) */
#thinking-block {
    height: auto;
    margin: 0;
    padding: 0;
    background: ansi_default;
    border: none;
}

#thinking-block.-collapsed {
    height: 1;
}

#thinking-block > Contents {
    background: ansi_default;
    padding: 0;
}

#thinking-view {
    text-style: dim;
    height: auto;
}

/* Generic utility */
.hidden {
    display: none;
}

/* Trait panel internals */
#trait-header {
    height: 1;
}

#trait-scroll {
    height: 1fr;
    overflow-y: auto;
}

#why-header {
    height: 1;
}

#why-scroll {
    height: 16;
    overflow-y: auto;
}

#why-content {
    height: auto;
}

.trait-category {
    text-style: bold;
    color: ansi_yellow;
    height: 1;
}

.trait-row {
    height: 1;
}

.trait-row-selected {
    height: auto;
    background: ansi_default;
}

#trait-hints {
    height: 1;
    color: ansi_default;
}
